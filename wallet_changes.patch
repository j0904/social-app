+  requireAltTextEnabled: false,
+  largeAltBadgeEnabled: false,
+  externalEmbeds: {},
+  invites: {
+    copiedInvites: [],
+  },
+  onboarding: {
+    step: 'Home',
+  },
+  hiddenPosts: [],
+  useInAppBrowser: undefined,
+  lastSelectedHomeFeed: undefined,
+  pdsAddressHistory: [],
+  disableHaptics: false,
+  disableAutoplay: false,
